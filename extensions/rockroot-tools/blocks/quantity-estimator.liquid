{% comment %} Quantity Estimator Block {% endcomment %}

<div class="rockroot-quantity-estimator" id="rockroot-qty-{{ block.id }}">
    <iframe src="/apps/tools/quantity-estimator" width="100%" height="{{ block.settings.height }}px" frameborder="0"
        scrolling="no" style="border:none; width:100%; display:block; min-height:{{ block.settings.height }}px;"
        title="Quantity Estimator"></iframe>
</div>

<style>
    .rockroot-quantity-estimator {
        width: 100%;

        margin: {
                {
                block.settings.margin_top
            }
        }

        px 0 {
                {
                block.settings.margin_bottom
            }
        }

        px 0;
    }

    @media (max-width: 768px) {
        .rockroot-quantity-estimator iframe {
            min-height: {
                    {
                    block.settings.mobile_height
                }
            }

            px;
        }
    }
</style>

{% schema %}
{
"name": "Quantity Estimator",
"target": "section",
"settings": [
{
"type": "range",
"id": "height",
"label": "Desktop Height (px)",
"min": 600,
"max": 1400,
"step": 50,
"default": 900
},
{
"type": "range",
"id": "mobile_height",
"label": "Mobile Height (px)",
"min": 800,
"max": 2000,
"step": 50,
"default": 1200
},
{
"type": "range",
"id": "margin_top",
"label": "Top Margin (px)",
"min": 0,
"max": 100,
"step": 5,
"default": 0
},
{
"type": "range",
"id": "margin_bottom",
"label": "Bottom Margin (px)",
"min": 0,
"max": 100,
"step": 5,
"default": 0
}
]
}
{% endschema %}